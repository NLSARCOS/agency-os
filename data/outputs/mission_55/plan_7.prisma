// schema.prisma additions
model Job {
  id          String    @id @default(cuid())
  type        JobType   // PDF_GENERATION | EMAIL_SEND
  status      JobStatus @default(QUEUED)
  tenantId    String
  payload     Json      // Job configuration
  result      Json?     // URLs, references
  error       Json?     // Error details if failed
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  
  events      JobEvent[]
  emailEvents EmailEvent[]
}

model JobEvent {
  id        String   @id @default(cuid())
  jobId     String
  stage     String   // pdf_start, pdf_complete, upload_complete, etc.
  metadata  Json?
  createdAt DateTime @default(now())
  
  job       Job      @relation(fields: [jobId], references: [id])
}

model EmailEvent {
  id        String   @id @default(cuid())
  jobId     String
  provider  String   // resend, ses, etc.
  messageId String   // Provider's message ID
  event     String   // sent, delivered, opened, bounced
  recipient String
  timestamp DateTime
  metadata  Json?    // IP, user_agent, etc.
  
  job       Job      @relation(fields: [jobId], references: [id])
  @@index([jobId, event])
  @@index([messageId])
}