# Agency OS — Environment Variables
# Copy to .env and fill in your API keys

# ── AI Providers ──────────────────────────────────────────
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Tools & Services ─────────────────────────────────────
GITHUB_TOKEN=
BRAVE_API_KEY=
PERPLEXITY_API_KEY=

# ── Optional Settings ────────────────────────────────────
# AGENCY_OS_ROOT=/path/to/agency-os  # Override auto-detection
# AGENCY_OS_LOG_LEVEL=INFO           # DEBUG, INFO, WARNING, ERROR
